# Environment Configuration for NGO Website Backend
# Copy this file to .env and fill in your values

# Database
# DATABASE_URL=sqlite:///./SKUMT_NGO.db

# Session Security (REQUIRED)
SESSION_SECRET_KEY=your_very_secure_random_key_here_change_this_in_production

# Environment
ENVIRONMENT=development  # or 'production'

# Admin Credentials (REQUIRED for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_test_key_here  # Use production key in production
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Email Configuration (Optional - for notifications)
EMAIL_PROVIDER=smtp  # or 'sendgrid'

# SMTP Configuration (for Gmail, Outlook, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your_app_password_here  # Use App Password for Gmail (2FA required)
SENDER_NAME=Shri Krishna Udhav Memorial Trust

# SendGrid Configuration (Optional - alternative to SMTP)
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# CORS (for frontend integration)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
